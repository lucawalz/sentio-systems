# ============================================
# Sentio Systems - Environment Configuration
# ============================================
# IMPORTANT: Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# --------------------------------------------
# Database Configuration
# --------------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=sentio
POSTGRES_PASSWORD=<generated>

# --------------------------------------------
# Keycloak Configuration
# --------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<generated>
KEYCLOAK_ADMIN_CLIENT_SECRET=<generated>

# --------------------------------------------
# MQTT Configuration
# --------------------------------------------
MQTT_PORT=1883
MQTT_ENABLED=true
MQTT_TOPICS=weather/data,animals/data,device/+/status
# Backend service account for subscribing to MQTT topics (auto-generated by setup-env.sh)
MQTT_USERNAME=sentio-mqtt
MQTT_PASSWORD=change-me-in-production
# External MQTT URL shown to users for device configuration (production: wss://mqtt.syslabs.dev)
MQTT_EXTERNAL_URL=mqtt://localhost:1883

# --------------------------------------------
# Backend Configuration
# --------------------------------------------
BACKEND_PORT=8083
JPA_HIBERNATE_DDL=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8083

# --------------------------------------------
# AI Services Configuration
# --------------------------------------------
# Service Ports
BIRDER_PORT=8000
SPECIESNET_PORT=8081
PREPROCESSING_PORT=8082

# Birder Model Configuration
BIRDER_MODEL_NAME=convnext_v2_tiny_intermediate-eu-common
PRELOAD_MODELS=true

# SpeciesNet Configuration
SPECIESNET_COUNTRY=DEU

# Classification Thresholds (shared across services)
CLASSIFICATION_THRESHOLD=0.01
MIN_CONFIDENCE=0.001
MAX_PREDICTIONS=5

# Logging Level for AI Services
AI_LOG_LEVEL=INFO

# Preprocessing Configuration
SAVE_IMAGES=false
BIRD_CLASSIFIER_URL=http://birder:8000/detect
SPECIES_CLASSIFIER_URL=http://speciesnet:8081/detect

# --------------------------------------------
# Redis Configuration (for session tracking & AI queue)
# --------------------------------------------
REDIS_PORT=6379
QUEUE_ENABLED=true

# ARQ Worker settings (optional, defaults shown)
# ARQ_MAX_JOBS=10
# ARQ_JOB_TIMEOUT=300

# --------------------------------------------
# Feature Flags
# --------------------------------------------
OPENMETEO_FORECAST_ENABLED=true
BRIGHTSKY_ALERTS_ENABLED=true
SWAGGER_ENABLED=true
SWAGGER_UI_ENABLED=true
PREPROCESSING_SERVICE_ENABLED=true

# --------------------------------------------
# n8n Workflow Integration
# --------------------------------------------
# n8n Keycloak client secret (generated by setup-env.sh)
N8N_CLIENT_SECRET=<generated>

# n8n webhook URL for triggering workflows
N8N_WEBHOOK_BASE_URL=https://n8n.syslabs.dev/webhook

# Workflow suffix: empty = production, "-local" = local development workflows
N8N_WORKFLOW_SUFFIX=

# --------------------------------------------
# Email Configuration (Resend)
# --------------------------------------------
# Resend API key (get from resend.com)
RESEND_API_KEY=re_xxxxxxxx

# Email sender address (must be verified domain)
RESEND_FROM_EMAIL=noreply@syslabs.dev

# Contact form recipient email
CONTACT_EMAIL_TO=team@syslabs.dev

# Frontend URL for email links (password reset, verification)
FRONTEND_URL=https://sentio.syslabs.dev
